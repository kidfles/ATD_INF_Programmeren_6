@{
    ViewData["Title"] = "Welkom";
}

<section class="py-4">
    <h1 class="display-5 fw-bold">FestivalTickets</h1>
    <p class="lead mb-4">Welkom bij FestivalTickets. Boek tickets in enkele stappen en beheer eenvoudig je boekingen.</p>

    @if (!User.Identity?.IsAuthenticated ?? false)
    {
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="BookingWizard" asp-action="Step1" class="btn btn-primary">Book a Ticket</a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">Login</a>
            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-secondary">Register</a>
        </div>
    }
    else if (User.IsInRole("Customer"))
    {
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="BookingWizard" asp-action="Step1" class="btn btn-primary">Book a Ticket</a>
            <a asp-controller="CustomerBookings" asp-action="Index" class="btn btn-outline-secondary">My Bookings</a>
        </div>
    }
    else if (User.IsInRole("Administrator"))
    {
        <div class="alert alert-info mb-3">Welcome, Administrator</div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="AdminBookings" asp-action="Index" class="btn btn-primary">Bookings</a>
            <a asp-controller="Festivals" asp-action="Index" class="btn btn-outline-secondary">Festivals</a>
            <a asp-controller="Packages" asp-action="Index" class="btn btn-outline-secondary">Packages</a>
            <a asp-controller="Items" asp-action="Index" class="btn btn-outline-secondary">Items</a>
        </div>
    }
</section>
