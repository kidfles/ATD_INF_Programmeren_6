@model IEnumerable<FestivalTickets.Domain.Booking>

@{
    ViewData["Title"] = "Alle boekingen";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Alle boekingen</h1>
    <a asp-action="ManageLoyalty" class="btn btn-outline-primary">Loyaliteitskaarten beheren</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Geen gegevens beschikbaar.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Boekingsdatum</th>
                    <th>Klant</th>
                    <th>Festival</th>
                    <th>Pakket</th>
                    <th>Aantal</th>
                    <th>Totaalprijs</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model)
                {
                    <tr>
                        <td>@booking.BookingDate.ToString("dd-MM-yyyy")</td>
                        <td>@($"{booking.Customer?.FirstName} {booking.Customer?.LastName}")</td>
                        <td>@(booking.Package?.Festival?.Name ?? "-")</td>
                        <td>@(booking.Package?.Name ?? "-")</td>
                        <td>@booking.Quantity</td>
                        <td>@booking.TotalPricePaid.ToString("C")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@booking.Id" class="btn btn-outline-primary btn-sm">Details</a>
                            <a asp-action="Delete" asp-route-id="@booking.Id" class="btn btn-outline-danger btn-sm">Verwijderen</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
