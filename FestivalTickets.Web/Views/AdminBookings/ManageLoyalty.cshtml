@model IEnumerable<FestivalTickets.Web.Models.LoyaltyViewModel>

@{
    ViewData["Title"] = "Loyaliteitskaarten Beheren";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h1>Loyaliteitskaarten Beheren</h1>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success mt-3 shadow-sm rounded-3">
        @TempData["Success"]
    </div>
}

<div class="card shadow-sm border-0 mt-3 rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">Klantnaam</th>
                        <th>E-mail</th>
                        <th class="text-center">Status</th>
                        <th class="text-center pe-4">Acties</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">Geen gegevens beschikbaar.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var vm in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-medium">@vm.FullName</td>
                                <td>@vm.Email</td>
                                <td class="text-center">
                                    @if (vm.HasLoyaltyCard)
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-2"><i class="bi bi-star-fill me-1"></i> Actief</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3 py-2 text-white">Geen</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    @if (vm.HasLoyaltyCard)
                                    {
                                        <form asp-action="RevokeLoyalty" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="customerId" value="@vm.CustomerId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                Intrekken
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="GrantLoyalty" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="customerId" value="@vm.CustomerId" />
                                            <button type="submit" class="btn btn-sm btn-outline-success rounded-pill px-3">
                                                Toekennen
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
